# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Azure SignalR
AZURE_SIGNALR_CONNECTION_STRING=Endpoint=https://your-signalr.service.signalr.net;AccessKey=...;Version=1.0;

# Keystone
KEYSTONE_URL=https://identity.alterspective.com.au
KEYSTONE_SERVICE_TOKEN=your-service-token
HANDOFF_TOKEN_SECRET=your-handoff-secret

# App
APP_ENV=local
PORT=3000
